local lastShot=0
_G.ShotConn=RunService.Heartbeat:Connect(function()
    if Mobile then return end
    local now=tick()
    if S.AutoShoot then
        local delay=math.max(0.05,S.AutoShootDelay/100)
        if now-lastShot>=delay and closestTarget() then
            lastShot=now; pcall(function() mouse1click() end)
        end
    end
    if S.TriggerBot then
        local t=closestTarget()
        if t and t.Character then
            local tp=targetPart(t.Character)
            if tp then
                local sp,on=Cam:WorldToViewportPoint(tp.Position)
                if on then
                    local sc=Vector2.new(Cam.ViewportSize.X/2,Cam.ViewportSize.Y/2)
                    local d=(Vector2.new(sp.X,sp.Y)-sc).Magnitude
                    if d<25 and now-lastShot>0.1 then
                        lastShot=now; pcall(function() mouse1click() end)
                    end
                end
            end
        end
    end
end)

