local KEY_MAP={RMB=Enum.UserInputType.MouseButton2,LMB=Enum.UserInputType.MouseButton1,MMB=Enum.UserInputType.MouseButton3}
local KEY_KB={
    E=Enum.KeyCode.E,F=Enum.KeyCode.F,Q=Enum.KeyCode.Q,R=Enum.KeyCode.R,
    G=Enum.KeyCode.G,X=Enum.KeyCode.X,Z=Enum.KeyCode.Z,V=Enum.KeyCode.V,
    CapsLock=Enum.KeyCode.CapsLock,
}
local function isAimActive()
    if Mobile then return Touching end
    local k=S.AimKey
    if KEY_MAP[k] then return UserInputService:IsMouseButtonPressed(KEY_MAP[k]) end
    if KEY_KB[k] then return UserInputService:IsKeyDown(KEY_KB[k]) end
    return false
end

local LOCK_PARTS={Head="Head",Neck="UpperTorso",Torso="HumanoidRootPart",Pelvis="LowerTorso"}
local function targetPart(char)
    local name=LOCK_PARTS[S.LockPart] or "Head"
    return char:FindFirstChild(name) or char:FindFirstChild("Head")
end

local function isVisible(char)
    if not S.VisibleCheck then return true end
    local tp=targetPart(char); if not tp then return false end
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances={char,LP.Character or workspace}
    rp.FilterType=Enum.RaycastFilterType.Exclude
    return not workspace:Raycast(Cam.CFrame.Position,tp.Position-Cam.CFrame.Position,rp)
end

local function validTarget(p)
    if p==LP or not p.Character then return false end
    local h=p.Character:FindFirstChildOfClass("Humanoid")
    if not h or h.Health<=0 then return false end
    if S.TeamCheck and LP.Team and p.Team and p.Team==LP.Team then return false end
    return true
end

local function closestTarget()
    local sc=Vector2.new(Cam.ViewportSize.X/2,Cam.ViewportSize.Y/2)
    local best,bestScore=nil,math.huge
    local lc=LP.Character
    local lr=lc and lc:FindFirstChild("HumanoidRootPart")
    for _,p in ipairs(Players:GetPlayers()) do
        if not validTarget(p) then continue end
        local char=p.Character
        local tp=targetPart(char)
        local root=char:FindFirstChild("HumanoidRootPart")
        if not tp or not root or not lr then continue end
        local dist3D=(root.Position-lr.Position).Magnitude
        if dist3D>S.LockRange then continue end
        if not isVisible(char) then continue end
        local sp,on=Cam:WorldToViewportPoint(tp.Position)
        if not on then continue end
        local screenDist=(Vector2.new(sp.X,sp.Y)-sc).Magnitude
        if screenDist>S.StickyRadius then continue end
        if S.FOVTargeting and S.ShowFOV and screenDist>S.FOVSize then continue end
        local score
        if S.TargetPriority=="HP" then
            local hum=char:FindFirstChildOfClass("Humanoid")
            score=hum and hum.Health or 100
        elseif S.TargetPriority=="Distance" then
            score=dist3D
        else score=screenDist end
        if score<bestScore then bestScore=score; best=p end
    end
    return best
end

_G.AimConn=RunService.RenderStepped:Connect(function()
    if not S.AimEnabled or not isAimActive() then return end
    local t=closestTarget(); if not t or not t.Character then return end
    local tp=targetPart(t.Character); if not tp then return end
    local aimPos=tp.Position
    if S.Prediction then
        local root=t.Character:FindFirstChild("HumanoidRootPart")
        if root and root:IsA("BasePart") then
            local vel=root.AssemblyLinearVelocity
            local dist=(Cam.CFrame.Position-tp.Position).Magnitude
            aimPos=tp.Position+vel*(dist/300)*S.PredictAmount*20
        end
    end
    Cam.CFrame=Cam.CFrame:Lerp(CFrame.lookAt(Cam.CFrame.Position,aimPos),S.Smoothing and S.Strength or 1)
end)

