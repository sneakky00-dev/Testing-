local function getBounds(char)
    local root=char:FindFirstChild("HumanoidRootPart")
    local head=char:FindFirstChild("Head")
    if not root or not head then return nil end
    local hp=Cam:WorldToViewportPoint(head.Position+Vector3.new(0,0.7,0))
    local fp=Cam:WorldToViewportPoint(root.Position-Vector3.new(0,3,0))
    if hp.Z<=0 then return nil end
    local h=math.abs(hp.Y-fp.Y); if h<3 then return nil end
    local w=h*0.55; local cx=(hp.X+fp.X)/2
    return {x=cx-w/2, y=hp.Y, w=w, h=h, cx=cx, bot=fp.Y, z=hp.Z, headX=hp.X, headY=hp.Y}
end

local function drawBone(bl,p1,p2,col)
    if not p1 or not p2 then bl.Visible=false; return end
    local s1=Cam:WorldToViewportPoint(p1.Position)
    local s2=Cam:WorldToViewportPoint(p2.Position)
    if s1.Z<=0 or s2.Z<=0 then bl.Visible=false; return end
    local dx,dy=s2.X-s1.X,s2.Y-s1.Y
    local ln=math.sqrt(dx*dx+dy*dy)
    if ln<1 then bl.Visible=false; return end
    bl.Visible=true; bl.BackgroundColor3=col
    bl.Size=UDim2.new(0,ln,0,1)
    bl.Position=UDim2.new(0,s1.X,0,s1.Y)
    bl.Rotation=math.deg(math.atan2(dy,dx))
end

