local ChamsStore={}
local ChamsFolder=Instance.new("Folder"); ChamsFolder.Name="ChamsFolder"
pcall(function() ChamsFolder.Parent=game:GetService("CoreGui") end)

local function updateChams()
    for p,sb in pairs(ChamsStore) do
        local char=p.Character
        local root=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        local alive=hum and hum.Health>0
        local teamOk=not(S.ChamsTeamCheck and LP.Team and p.Team and LP.Team==p.Team)
        local show=S.ChamsEnabled and char and root and alive and teamOk
        sb.Visible=show or false
        if show then
            local col=resolveColor(S.ChamsColor,nil,p)
            sb.Color3=col; sb.SurfaceColor3=col
            sb.SurfaceTransparency=1-(S.ChamsOpacity/100)
            sb.LineThickness=0.04
        end
    end
end

local function makeChams(p)
    if ChamsStore[p] or p==LP then return end
    local sb=Instance.new("SelectionBox")
    sb.SurfaceTransparency=0.6; sb.LineThickness=0.04
    sb.Color3=Color3.fromRGB(255,60,60); sb.SurfaceColor3=Color3.fromRGB(255,60,60)
    sb.Parent=ChamsFolder; ChamsStore[p]=sb
    local function link(char) sb.Adornee=char end
    if p.Character then link(p.Character) end
    p.CharacterAdded:Connect(function(c) task.wait(0.5); link(c) end)
end
local function dropChams(p)
    if ChamsStore[p] then pcall(function() ChamsStore[p]:Destroy() end); ChamsStore[p]=nil end
end
for _,p in ipairs(Players:GetPlayers()) do makeChams(p) end
Players.PlayerAdded:Connect(makeChams); Players.PlayerRemoving:Connect(dropChams)
_G.ChamsConn=RunService.Heartbeat:Connect(updateChams)

