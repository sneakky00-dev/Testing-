local hitMarkerActive=false
local function buildCrosshair()
    kill("CrosshairGui")
    local ok,cg=pcall(function() return game:GetService("CoreGui") end)
    local cg2=Instance.new("ScreenGui")
    cg2.Name="CrosshairGui"; cg2.ResetOnSpawn=false; cg2.IgnoreGuiInset=true; cg2.DisplayOrder=9996
    cg2.Parent=(ok and cg) or LP:WaitForChild("PlayerGui"); _G.CrosshairGui=cg2

    local function mkF()
        local f=Instance.new("Frame")
        f.AnchorPoint=Vector2.new(0,0)
        f.BorderSizePixel=0; f.Parent=cg2; return f
    end
    local L1,L2,L3,L4=mkF(),mkF(),mkF(),mkF()

    local dot=Instance.new("Frame"); dot.BorderSizePixel=0; dot.Parent=cg2
    Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

    local ring=Instance.new("Frame"); ring.BackgroundTransparency=1; ring.BorderSizePixel=0; ring.Parent=cg2
    local ringSt=Instance.new("UIStroke"); ringSt.Thickness=2; ringSt.Parent=ring
    Instance.new("UICorner",ring).CornerRadius=UDim.new(1,0)

    local hitLines={}
    for i=1,4 do
        local h=Instance.new("Frame"); h.AnchorPoint=Vector2.new(0.5,0.5)
        h.BorderSizePixel=0; h.BackgroundColor3=Color3.fromRGB(255,80,80)
        h.Visible=false; h.ZIndex=10; h.Parent=cg2
        hitLines[i]=h
    end

    RunService.RenderStepped:Connect(function()
        local vw,vh=Cam.ViewportSize.X,Cam.ViewportSize.Y
        local cx,cy=vw/2,vh/2
        local sz=S.CrosshairSize; local gap=S.CrosshairGap; local th=S.CrosshairThick
        local col=resolveColor(S.CrosshairColor,Color3.fromRGB(235,70,115))
        local vis=S.CrosshairEnabled
        local sty=S.CrosshairStyle

        L1.Visible=false; L2.Visible=false; L3.Visible=false; L4.Visible=false
        dot.Visible=false; ring.Visible=false

        if vis and (sty=="Cross" or sty=="T") then
            L1.Visible=true; L3.Visible=true; L4.Visible=true
            if sty=="Cross" then L2.Visible=true end
            L1.BackgroundColor3=col; L1.Size=UDim2.new(0,th,0,sz)
            L1.Position=UDim2.new(0,cx-th/2,0,cy-gap-sz)
            L2.BackgroundColor3=col; L2.Size=UDim2.new(0,th,0,sz)
            L2.Position=UDim2.new(0,cx-th/2,0,cy+gap)
            L3.BackgroundColor3=col; L3.Size=UDim2.new(0,sz,0,th)
            L3.Position=UDim2.new(0,cx-gap-sz,0,cy-th/2)
            L4.BackgroundColor3=col; L4.Size=UDim2.new(0,sz,0,th)
            L4.Position=UDim2.new(0,cx+gap,0,cy-th/2)
        elseif vis and sty=="Dot" then
            dot.Visible=true; dot.BackgroundColor3=col
            local ds=th*3
            dot.Size=UDim2.new(0,ds,0,ds); dot.Position=UDim2.new(0,cx-ds/2,0,cy-ds/2)
        elseif vis and sty=="Circle" then
            ring.Visible=true; ringSt.Color=col
            local r=sz+gap
            ring.Size=UDim2.new(0,r*2,0,r*2); ring.Position=UDim2.new(0,cx-r,0,cy-r)
        end

        local hml=Mobile and 12 or 16
        for i,h in ipairs(hitLines) do
            h.Visible=S.HitMarker and hitMarkerActive
            if h.Visible then
                h.Size=UDim2.new(0,hml,0,th+1)
                h.Rotation=(i-1)*90+45
                h.Position=UDim2.new(0,cx,0,cy)
            end
        end
    end)
end
buildCrosshair()

