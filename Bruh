            local d=Instance.new("Frame"); d.BackgroundColor3=Color3.fromRGB(255,60,60)
            d.BorderSizePixel=0; d.Size=UDim2.new(0,6,0,6); d.AnchorPoint=Vector2.new(0.5,0.5)
            d.ZIndex=6; d.Parent=radarBg
            Instance.new("UICorner",d).CornerRadius=UDim.new(1,0)
            radarDots[i]=d
