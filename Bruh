local KillFeedConns={}
local showFeedFn=nil
local showDmgFn=nil

local function buildKillFeed()
    kill("KillGui")
    for _,c in pairs(KillFeedConns) do pcall(function() c:Disconnect() end) end
    KillFeedConns={}
    local ok,cg=pcall(function() return game:GetService("CoreGui") end)
    local kg=Instance.new("ScreenGui")
    kg.Name="KillGui"; kg.ResetOnSpawn=false; kg.IgnoreGuiInset=true; kg.DisplayOrder=9995
    kg.Parent=(ok and cg) or LP:WaitForChild("PlayerGui"); _G.KillGui=kg

    local pool={}

    showFeedFn=function(msg,col)
        if not S.KillFeed then return end
        for i=#pool,1,-1 do if not pool[i].Parent then table.remove(pool,i) end end
        local lbl=Instance.new("TextLabel")
        lbl.BackgroundColor3=Color3.fromRGB(10,10,18); lbl.BackgroundTransparency=0.25
        lbl.TextColor3=col or Color3.fromRGB(235,70,115)
        lbl.TextSize=Mobile and 11 or 13; lbl.Font=Enum.Font.GothamBold
        lbl.Text=" "..msg.." "; lbl.TextXAlignment=Enum.TextXAlignment.Left
        lbl.Size=UDim2.new(0,Mobile and 170 or 215,0,Mobile and 20 or 24)
        lbl.AnchorPoint=Vector2.new(1,0)
        lbl.Position=UDim2.new(1,-4,0,4+#pool*(Mobile and 24 or 28))
        lbl.BorderSizePixel=0; lbl.ZIndex=10; lbl.Parent=kg
        Instance.new("UICorner",lbl).CornerRadius=UDim.new(0,4)
        table.insert(pool,lbl)
        task.delay(3,function()
            for i=1,20 do
                pcall(function()
                    lbl.TextTransparency=i/20
                    lbl.BackgroundTransparency=0.25+0.75*(i/20)
                end)
                task.wait(0.05)
            end
            pcall(function() lbl:Destroy() end)
            local idx=table.find(pool,lbl)
            if idx then table.remove(pool,idx) end
        end)
    end

    showDmgFn=function(screenX,screenY,dmg,isCrit)
        if not S.DamageNumbers then return end
        local lbl=Instance.new("TextLabel")
        lbl.BackgroundTransparency=1
        lbl.TextColor3=isCrit and Color3.fromRGB(255,220,50) or Color3.fromRGB(255,80,80)
        lbl.TextSize=isCrit and (Mobile and 16 or 20) or (Mobile and 12 or 15)
        lbl.Font=Enum.Font.GothamBold
        lbl.Text=(isCrit and "⚡" or "")..math.floor(dmg)..(isCrit and "!" or "")
        lbl.Size=UDim2.new(0,80,0,24); lbl.AnchorPoint=Vector2.new(0.5,0.5)
        lbl.Position=UDim2.new(0,screenX,0,screenY)
        lbl.TextStrokeTransparency=0.3; lbl.BorderSizePixel=0; lbl.ZIndex=15; lbl.Parent=kg
        task.spawn(function()
            for i=1,20 do
                pcall(function()
                    lbl.Position=UDim2.new(0,screenX,0,screenY-(i*2.5))
                    lbl.TextTransparency=i>12 and (i-12)/8 or 0
                end)
                task.wait(0.04)
            end
            pcall(function() lbl:Destroy() end)
        end)
    end

    local function watchPlayer(p)
        if p==LP then return end
        local function hookChar(char)
            local hum=char:WaitForChildWhichIsA("Humanoid",5)
            if not hum then return end
            local lastHP=hum.Health
            local conn=hum:GetPropertyChangedSignal("Health"):Connect(function()
                local hp=hum.Health
                if hp<lastHP then
                    local dmg=lastHP-hp
                    if hp<=0 then
                        showFeedFn and showFeedFn("☠ "..p.Name.." eliminated",Color3.fromRGB(235,70,115))
                    else
                        showFeedFn and showFeedFn("⚡ "..p.Name.." -"..math.floor(dmg).." HP",Color3.fromRGB(220,200,80))
                    end
                    hitMarkerActive=true; task.delay(0.15,function() hitMarkerActive=false end)
                    if showDmgFn then
                        local root=char:FindFirstChild("HumanoidRootPart")
                        if root then
                            local sp,on=Cam:WorldToViewportPoint(root.Position)
                            if on then showDmgFn(sp.X+math.random(-15,15),sp.Y-20,dmg,dmg>=50) end
                        end
                    end
                end
                lastHP=hp
            end)
            KillFeedConns[p]=conn
        end
        if p.Character then task.spawn(hookChar,p.Character) end
        p.CharacterAdded:Connect(function(c) task.wait(0.5); hookChar(c) end)
    end
    for _,p in ipairs(Players:GetPlayers()) do watchPlayer(p) end
    Players.PlayerAdded:Connect(watchPlayer)
end
