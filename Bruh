local mouse=LP:GetMouse()
mouse.Button1Down:Connect(function()
    if not S.SilentAim then return end
    local t=closestTarget(); if not t or not t.Character then return end
    local tp=targetPart(t.Character); if not tp then return end
    local saved=Cam.CFrame
    Cam.CFrame=CFrame.lookAt(Cam.CFrame.Position,tp.Position)
