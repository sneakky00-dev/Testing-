        if tick()-fpsT>=0.5 then fps=math.floor(frameCount/(tick()-fpsT)); frameCount=0; fpsT=tick() end

        fpsLbl.Visible=S.FPSCounter
        if S.FPSCounter then
            fpsLbl.Text="FPS: "..fps
            fpsLbl.TextColor3=fps>=50 and Color3.fromRGB(80,220,80) or fps>=30 and Color3.fromRGB(220,200,80) or Color3.fromRGB(220,80,80)
            fpsLbl.Position=UDim2.new(1,-4,0,Mobile and 40 or 50)
        end

        spdLbl.Visible=S.Speedometer
        if S.Speedometer then
            local char=LP.Character; local root=char and char:FindFirstChild("HumanoidRootPart")
            local spd=root and math.floor(root.AssemblyLinearVelocity.Magnitude) or 0
            spdLbl.Text="SPD: "..spd
            spdLbl.Position=UDim2.new(1,-4,0,(Mobile and 40 or 50)+(S.FPSCounter and 19 or 0))
        end

        radarBg.Visible=S.MiniRadar
        if S.MiniRadar then
            radarBg.Position=UDim2.new(1,-4,1,-(Mobile and 100 or 120))
            local myRoot=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            local camYaw=math.atan2(-Cam.CFrame.LookVector.X,-Cam.CFrame.LookVector.Z)
            local di=0
            for _,p in ipairs(Players:GetPlayers()) do
                if p==LP or not validTarget(p) then continue end
                local eRoot=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if not eRoot or not myRoot then continue end
                di=di+1; local d=getRadarDot(di)
                local rel=eRoot.Position-myRoot.Position
                local rx,rz=rel.X,rel.Z
                local rotX=rx*math.cos(camYaw)-rz*math.sin(camYaw)
                local rotZ=rx*math.sin(camYaw)+rz*math.cos(camYaw)
                local scale=RRAD/S.RadarRange
                local dx,dz=rotX*scale,rotZ*scale
                local dist2d=math.sqrt(dx*dx+dz*dz)
                if dist2d>RRAD-4 then dx=dx/dist2d*(RRAD-4); dz=dz/dist2d*(RRAD-4) end
                d.Visible=true; d.Position=UDim2.new(0.5,dx,0.5,-dz)
                d.BackgroundColor3=resolveColor(S.ESPColor,nil,p)
            end
            for i=di+1,#radarDots do radarDots[i].Visible=false end
        end
    end)
end
